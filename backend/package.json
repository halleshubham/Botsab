    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "https-proxy-agent": "^9.1.0",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.3",
    "pino": "^8.18.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.2",
    "socks-proxy-agent": "^10.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.2",
    "@types/qrcode": "^1.5.5",
    "nodemon": "^3.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
