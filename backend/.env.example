# ─────────────────────────────────────────────
#  Botsab — environment variables
#  Copy this file to .env and fill in the values
#  Lines marked REQUIRED must be set; everything
#  else has a safe default for local development.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=production          # development | production

# ── Database  (REQUIRED) ──────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/botsab

# ── Auth  (REQUIRED) ──────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string_in_production
BCRYPT_ROUNDS=12

# ── Superadmin  (REQUIRED) ────────────────────
# The first account registered with this email is promoted to superadmin
# and granted unlimited instance access automatically.
SUPERADMIN_EMAIL=admin@yourdomain.com

# ── App public URL  (REQUIRED for email links) ─
# Used in approval / registration emails. Must be the URL users open in their browser.
APP_URL=https://yourdomain.com

# ── WhatsApp session storage ──────────────────
SESSIONS_DIR=./sessions

# ── Media uploads (images sent via campaigns) ─
UPLOADS_DIR=./uploads

# ── Rate limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Webhooks ──────────────────────────────────
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# ── SMTP email  (OPTIONAL) ────────────────────
# Leave SMTP_USER blank to disable all email notifications.
# Emails are skipped silently when not configured — the app works fine without them.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to Google Account → Security → App Passwords.
#   3. Create an app password named "Botsab" and paste it below.
#   Note: your regular Gmail password will NOT work here.
#
# Other providers (e.g. Brevo, Mailgun, Postmark):
#   Change SMTP_HOST / SMTP_PORT / SMTP_SECURE to match your provider.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true             # true = SSL/TLS (port 465); false = STARTTLS (port 587)
SMTP_USER=                   # your Gmail address, e.g. you@gmail.com
SMTP_PASS=                   # 16-character App Password from Google
# SMTP_FROM="Botsab <you@gmail.com>"   # optional — defaults to SMTP_USER
