# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_random_password

# ── App ───────────────────────────────────────────────────────────────────────
SUPERADMIN_EMAIL=your@email.com

# Port nginx listens on (change to 443 when adding SSL)
HTTP_PORT=80

# ── App public URL (REQUIRED for email links) ─────────────────────────────────
APP_URL=https://yourdomain.com

# ── SMTP email (OPTIONAL) ─────────────────────────────────────────────────────
# Leave SMTP_USER blank to disable email notifications entirely.
# Gmail: enable 2FA → Google Account → Security → App Passwords → create one.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# SMTP_FROM="Botsab <you@gmail.com>"   # optional — defaults to SMTP_USER

# ── Optional tuning (defaults shown) ─────────────────────────────────────────
# BCRYPT_ROUNDS=12
# WEBHOOK_TIMEOUT_MS=10000
# WEBHOOK_MAX_RETRIES=3
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
